# --- Фронт (Vite) ---
# Пусто = относительные запросы + proxy Vite на API :4000
# На проде: полный URL сервиса API (Railway), без завершающего /
# VITE_API_URL=https://your-api.up.railway.app

# --- API (Railway / локально) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_SECRET=change-me-long-random
CRM_WEBHOOK_SECRET=shared-with-btt-site-hmac
PUBLIC_BASE_URL=https://your-api.up.railway.app
# В проде обычно false. Включайте true только для первоначальной регистрации.
ALLOW_SELF_SIGNUP=false
# Список разрешённых Origin через запятую для CORS.
# Если пусто, API разрешает любой origin (не рекомендуется для прода).
# CORS_ORIGINS=https://crm.example.com,https://staging-crm.example.com
# Опционально для Telegram webhook source verification.
# TELEGRAM_WEBHOOK_SECRET=some-random-secret-token

# Опционально: Nexus / AI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Порт локального API (server/entry.ts)
# PORT=4000
